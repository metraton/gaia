#!/usr/bin/env python3
"""
gaia -- Unified Gaia CLI

Entry point that discovers subcommand plugins from bin/cli/ and dispatches
to the matching handler. Zero external dependencies (stdlib only).

Usage:
    python bin/gaia <subcommand> [options]
    python bin/gaia --help
    python bin/gaia status [--json]
    python bin/gaia doctor [--json] [--fix]
"""

import argparse
import importlib
import importlib.util
import os
import subprocess
import sys
from pathlib import Path

# Ensure the package root is on sys.path so submodules resolve correctly.
_SCRIPT_DIR = Path(__file__).resolve().parent
_PACKAGE_ROOT = _SCRIPT_DIR.parent
if str(_PACKAGE_ROOT) not in sys.path:
    sys.path.insert(0, str(_PACKAGE_ROOT))
# Also ensure bin/ is on the path so bin/cli/ resolves as a package.
if str(_SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(_SCRIPT_DIR))

_CLI_DIR = _SCRIPT_DIR / "cli"

# Subcommands that must NOT trigger the lazy DB bootstrap:
#   - install:   bootstraps the DB itself (Step 1); double-bootstrap is wasteful.
#   - uninstall: tearing Gaia down -- recreating the DB would be perverse.
_LAZY_BOOTSTRAP_SKIP = frozenset({"install", "uninstall"})


def _resolve_db_path():
    """Resolve the gaia.db path (honours the GAIA_DB override, else ~/.gaia)."""
    env = os.environ.get("GAIA_DB")
    if env:
        return Path(env).expanduser()
    return Path("~/.gaia/gaia.db").expanduser()


def _ensure_db_bootstrapped(subcommand):
    """Lazily bootstrap ~/.gaia/gaia.db on first CLI use if it is absent.

    This is the non-invasive replacement for the removed npm ``postinstall``
    hook. It runs on the first real CLI use rather than at package-install
    time, so it behaves identically under npm, pnpm (which ignores lifecycle
    scripts by default), and the Claude Code plugin install -- none of which
    are required to run a postinstall step. Best-effort and quiet: a failure
    here never blocks the requested subcommand (the command surfaces its own
    DB error, and ``gaia doctor`` reports the root cause).
    """
    if subcommand in _LAZY_BOOTSTRAP_SKIP:
        return
    try:
        db = _resolve_db_path()
        if db.exists():
            return
        bootstrap = _PACKAGE_ROOT / "scripts" / "bootstrap_database.sh"
        if not bootstrap.is_file():
            return
        env = os.environ.copy()
        env["GAIA_DB"] = str(db)
        subprocess.run(
            ["bash", str(bootstrap)],
            env=env,
            capture_output=True,
            text=True,
            check=False,
            timeout=120,
        )
        # Mirror `gaia install` Step 1a: seed agent_contract_permissions from
        # agent frontmatters (bootstrap.sh already seeds agent_permissions).
        seeder = _PACKAGE_ROOT / "tools" / "scan" / "seed_contract_permissions.py"
        if db.exists() and seeder.is_file():
            subprocess.run(
                [sys.executable or "python3", str(seeder), "--db-path", str(db)],
                env=env,
                capture_output=True,
                text=True,
                check=False,
                timeout=30,
            )
    except Exception:
        # Lazy bootstrap must never break the CLI.
        pass


def _discover_plugins():
    """Return a sorted list of (module_name, module) for all bin/cli/*.py plugins."""
    plugins = []
    if not _CLI_DIR.is_dir():
        return plugins

    for path in sorted(_CLI_DIR.glob("*.py")):
        if path.stem == "__init__":
            continue
        spec = importlib.util.spec_from_file_location(f"cli.{path.stem}", path)
        if spec is None:
            continue
        try:
            mod = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)
            plugins.append((path.stem, mod))
        except Exception as exc:  # noqa: BLE001
            print(f"Warning: could not load plugin {path.name}: {exc}", file=sys.stderr)

    return plugins


# ---------------------------------------------------------------------------
# Fast path: import ONE plugin instead of all ~28
# ---------------------------------------------------------------------------
#
# Profiling showed ``_discover_plugins()`` eagerly imports (exec_module) every
# bin/cli/*.py file on EVERY invocation, even ``gaia contract view`` or
# ``gaia history``, purely so argparse has every subparser registered. That
# cost is dominated by whichever plugin happens to carry an expensive
# module-level import (see bin/cli/metrics.py's now-lazy NATIVE_AGENT_NAMES),
# but even after that fix, importing 27 unrelated modules per invocation is
# pure waste for the overwhelmingly common case: ``gaia <subcmd> [args...]``
# where <subcmd> is a real, exactly-named subcommand.
#
# The fast path below imports ONLY the one bin/cli/<name>.py file matching
# argv[0] and builds a parser with ONLY that subcommand registered. It is
# used ONLY when argparse does not need the full subparser set to behave
# correctly, and declines (returns None / falls through) in every case where
# full parity requires it:
#   - empty argv                     -> top-level help lists every subcommand
#   - "-h"/"--help" anywhere in argv -> help text/formatting needs full context
#   - a leading flag (e.g. --json, --version) before the subcommand
#   - a first token that isn't a real plugin file (typo -- argparse's
#     "invalid choice" error must enumerate every valid subcommand)
#
# _discover_plugins() itself is UNCHANGED and still runs for every one of
# those fallback cases (and is what the CLI dispatcher's mutative-verb
# recognizer -- hooks/modules/security/mutative_verbs.py's
# _check_gaia_cli_dispatcher / _GAIA_DISPATCHER_SIGNATURE -- keys off of by
# literal name; it also keys off this module's "Unified Gaia CLI" docstring
# text above. Both markers are preserved verbatim by this change.
_FAST_PATH_DISABLE_ENV = "GAIA_CLI_NO_FAST_PATH"


def _fast_path_subcommand(argv):
    """Return the subcommand name ``argv`` unambiguously names, else ``None``.

    A ``None`` return means "fall back to full discovery" -- see the module
    comment above for the exact list of cases that decline.
    """
    if not argv:
        return None
    if any(a in ("-h", "--help") for a in argv):
        return None
    first = argv[0]
    if not first or first.startswith("-"):
        return None
    if not _CLI_DIR.is_dir():
        return None
    if not (_CLI_DIR / f"{first}.py").is_file():
        return None
    return first


def _load_single_plugin(stem):
    """Import exactly one bin/cli/<stem>.py plugin module, or None on failure.

    Deliberately silent on failure (unlike ``_discover_plugins``, which
    prints a warning): a failure here just means the fast path does not
    apply, and the caller falls back to ``_discover_plugins()``, which
    re-attempts the same import and prints the warning exactly once --
    matching pre-fast-path behavior byte-for-byte.
    """
    path = _CLI_DIR / f"{stem}.py"
    if not path.is_file():
        return None
    spec = importlib.util.spec_from_file_location(f"cli.{stem}", path)
    if spec is None:
        return None
    try:
        mod = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(mod)
        return mod
    except Exception:  # noqa: BLE001
        return None


def _build_parser(plugin_entries):
    """Build the top-level ArgumentParser and register the given plugins.

    ``plugin_entries`` is a list of (name, module) pairs -- either the full
    set from ``_discover_plugins()`` or the single-entry fast path list.
    """
    parser = argparse.ArgumentParser(
        prog="gaia",
        description="Gaia unified CLI -- manage and inspect your Gaia installation.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--json",
        action="store_true",
        default=False,
        help="Output results as JSON (machine-readable)",
    )
    parser.add_argument(
        "--version",
        dest="show_version",
        action="store_true",
        default=False,
        help="Print version and exit",
    )

    subparsers = parser.add_subparsers(dest="subcommand", metavar="<subcommand>")
    for _name, mod in plugin_entries:
        if hasattr(mod, "register"):
            mod.register(subparsers)

    return parser


def _run_with_plugins(argv, plugins):
    """Parse argv against ``plugins`` and dispatch. Shared by both paths."""
    parser = _build_parser(plugins)
    args = parser.parse_args(argv)

    if args.show_version:
        # Print version from package.json
        try:
            import json
            pkg = _PACKAGE_ROOT / "package.json"
            version = json.loads(pkg.read_text())["version"]
            print(f"gaia {version}")
        except Exception:
            print("gaia (version unknown)")
        return 0

    if args.subcommand is None:
        parser.print_help()
        return 0

    # Lazy, non-invasive DB bootstrap -- replaces the removed npm postinstall.
    # Runs once, only when ~/.gaia/gaia.db is absent, and never for the
    # install/uninstall subcommands (see _LAZY_BOOTSTRAP_SKIP).
    _ensure_db_bootstrapped(args.subcommand)

    # Dispatch to the matching plugin handler
    for name, mod in plugins:
        if name == args.subcommand and hasattr(mod, f"cmd_{name}"):
            handler = getattr(mod, f"cmd_{name}")
            return handler(args) or 0

    # Subcommand registered but handler not found -- should not happen
    print(f"gaia: unknown subcommand '{args.subcommand}'", file=sys.stderr)
    return 1


def main(argv=None):
    """CLI entry point. Returns exit code."""
    raw_argv = sys.argv[1:] if argv is None else list(argv)

    if not os.environ.get(_FAST_PATH_DISABLE_ENV):
        fast_name = _fast_path_subcommand(raw_argv)
        if fast_name is not None:
            mod = _load_single_plugin(fast_name)
            if mod is not None:
                return _run_with_plugins(raw_argv, [(fast_name, mod)])
            # Fast-path import failed -- fall through to full discovery,
            # which re-attempts the same import and reports the warning.

    plugins = _discover_plugins()
    return _run_with_plugins(raw_argv, plugins)


if __name__ == "__main__":
    sys.exit(main())
