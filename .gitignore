# Secrets and credentials
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
service-account*.json

# Dependencies
node_modules/


# Python
uv.lock
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Testing
.coverage
htmlcov/
.tox/
coverage/

# Claude runtime directories (created by tests or development)
# This should NOT exist in the package - only in consuming projects
.claude/

# Spec-Kit specs (local design artifacts, not shipped)
specs/

# Distribution builds (generated on-demand by npm pack/publish)
*.egg-info/
*.tgz
.npm-cache/
/dist/

# Gaia brief evidence: raw artifacts ignored, INDEX.md committed for auditability
.claude/project-context/briefs/*/evidence/*
!.claude/project-context/briefs/*/evidence/INDEX.md

# Transient eval smoke run artifacts (baseline.json is tracked)
tests/evals/results/*-smoke.json

# Temporary probe/test artifacts
tmp-*
probe-*.md

# Pytest temp dir (basetemp in pyproject.toml)
.pytest-tmp/

# Evidence dir (repo-root scratch, prevent re-accumulation).
# Anchored with leading slash so tests/evals/evidence/ (the permanent
# AC-evidence store) is NOT excluded by this rule.
/evidence/

# Stray root-level Gaia DB (0-byte connect-then-abort leak / relative --db-path).
# The canonical DB lives at ~/.gaia/gaia.db (GAIA_DATA_DIR); a gaia.db at the
# repo root is always a leak. Anchored with a leading slash so legitimate .db
# files elsewhere in the repo are NOT ignored.
/gaia.db

# Cosmic-ray mutation-testing session databases (ephemeral per-run scratch).
# The permanent config lives at tests/evals/mutation-security-core.toml and IS
# tracked; the .sqlite session files it produces are regenerable and are not.
*.sqlite
# AC-3 spike scratch (superseded by tests/evals/mutation-security-core.toml)
tiers-spike.sqlite
mutation-tiers-spike.toml
# Cosmic-ray working directory (mutated copies of source, never committed)
mutants/

# Skills validation scratch report (regenerated on-demand, not shipped)
tools/validation/skills_report.md
