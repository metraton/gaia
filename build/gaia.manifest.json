{
  "plugin_name": "gaia",
  "version": "from:package.json",
  "description": "Security-first multi-agent orchestration for Claude Code. Agents span the full lifecycle; commands are risk-classified — reads run free, state changes need approval, irreversible ops blocked.",
  "hooks": {
    "entries": [
      "hooks/pre_tool_use.py",
      "hooks/post_tool_use.py",
      "hooks/stop_hook.py",
      "hooks/user_prompt_submit.py",
      "hooks/subagent_start.py",
      "hooks/subagent_stop.py",
      "hooks/session_start.py",
      "hooks/session_end_hook.py",
      "hooks/task_completed.py",
      "hooks/pre_compact.py",
      "hooks/post_compact.py"
    ],
    "matchers": {
      "PreToolUse": [
        {"matcher": "Bash"},
        {"matcher": "Task"},
        {"matcher": "Agent"},
        {"matcher": "SendMessage"},
        {"matcher": "Write"},
        {"matcher": "Edit"}
      ],
      "PostToolUse": [
        {"matcher": "Bash"},
        {"matcher": "AskUserQuestion"}
      ],
      "SubagentStop": [{"matcher": "*"}],
      "SessionStart": [{"matcher": "startup"}],
      "SessionEnd": [
        {"matcher": "prompt_input_exit"},
        {"matcher": "logout"},
        {"matcher": "other"}
      ],
      "PreCompact": [{}],
      "PostCompact": [{}],
      "Stop": [{}],
      "TaskCompleted": [{}],
      "SubagentStart": [{"matcher": "*"}],
      "UserPromptSubmit": [{}]
    }
  },
  "modules": "all",
  "agents": [
    "agents/gaia-orchestrator.md",
    "agents/gaia-operator.md",
    "agents/gaia-system.md",
    "agents/developer.md",
    "agents/cloud-troubleshooter.md",
    "agents/gitops-operator.md",
    "agents/platform-architect.md",
    "agents/gaia-planner.md"
  ],
  "skills": "all",
  "commands": [],
  "tools": "all",
  "config": "all",
  "bin": [
    "bin/gaia",
    "bin/cli/"
  ],
  "include": [
    "gaia/",
    "scripts/bootstrap_database.sh",
    "scripts/seed_agent_permissions.py",
    "scripts/check_schema_drift.py",
    "scripts/migrations/"
  ],
  "settings": {
    "permissions": {
      "allow": [
        "BashOutput",
        "ExitPlanMode",
        "Glob",
        "Grep",
        "KillShell",
        "Read",
        "Skill",
        "SlashCommand",
        "Task",
        "Agent",
        "SendMessage",
        "TodoWrite",
        "WebFetch",
        "WebSearch",
        "mcp__ide__executeCode",
        "mcp__ide__getDiagnostics",
        "Edit(/tmp/*)",
        "Write(/tmp/*)",
        "NotebookEdit",
        "Bash(*)"
      ],
      "deny": [
        "Bash(aws ec2 delete-vpc:*)",
        "Bash(aws ec2 delete-subnet:*)",
        "Bash(aws ec2 delete-internet-gateway:*)",
        "Bash(aws ec2 delete-route-table:*)",
        "Bash(aws ec2 delete-route:*)",
        "Bash(aws rds delete-db-instance:*)",
        "Bash(aws rds delete-db-cluster:*)",
        "Bash(aws dynamodb delete-table:*)",
        "Bash(aws s3 rb:*)",
        "Bash(aws s3api delete-bucket:*)",
        "Bash(aws elasticache delete-cache-cluster:*)",
        "Bash(aws elasticache delete-replication-group:*)",
        "Bash(aws eks delete-cluster:*)",
        "Bash(gcloud projects delete:*)",
        "Bash(gcloud container clusters delete:*)",
        "Bash(gcloud sql instances delete:*)",
        "Bash(gcloud sql databases delete:*)",
        "Bash(gcloud services disable:*)",
        "Bash(gsutil rb:*)",
        "Bash(gsutil rm -r:*)",
        "Bash(kubectl delete namespace:*)",
        "Bash(kubectl delete node:*)",
        "Bash(kubectl delete cluster:*)",
        "Bash(kubectl delete pv:*)",
        "Bash(kubectl delete persistentvolume:*)",
        "Bash(kubectl delete pvc:*)",
        "Bash(kubectl delete persistentvolumeclaim:*)",
        "Bash(kubectl delete crd:*)",
        "Bash(kubectl delete customresourcedefinition:*)",
        "Bash(kubectl delete mutatingwebhookconfiguration:*)",
        "Bash(kubectl delete validatingwebhookconfiguration:*)",
        "Bash(kubectl drain:*)",
        "Bash(git push --force:*)",
        "Bash(git push -f:*)",
        "Bash(git push origin --force:*)",
        "Bash(git push origin -f:*)",
        "Bash(dd:*)",
        "Bash(fdisk:*)",
        "Bash(mkfs:*)",
        "Bash(mkfs.ext4:*)",
        "Bash(mkfs.ext3:*)",
        "Bash(mkfs.fat:*)",
        "Bash(mkfs.ntfs:*)"
      ],
      "ask": []
    }
  }
}
