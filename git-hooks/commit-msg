#!/bin/sh
#
# commit-msg hook: strip Claude Code / AI-tool attribution footers from
# commit messages.
#
# This hook runs at the git level, catching ALL commits regardless of whether
# they originate from Claude Code's Bash tool, a subagent, or the user's
# terminal. It is layer 4 of the defense-in-depth chain documented in
# hooks/modules/tools/bash_validator.py, and the ONLY layer that catches a
# commit made outside Claude Code's Bash tool entirely -- a plain terminal
# `git commit`, an IDE commit, or `git commit -F <file>` (none of which the
# PreToolUse hook's command-string scan ever sees).
#
# Patterns are kept ALIGNED with FORBIDDEN_FOOTER_PATTERNS /
# _strip_claude_footers() in hooks/modules/tools/bash_validator.py, which is
# the single source of truth for what constitutes a forbidden footer. If a
# pattern is added there, add its equivalent here too.
#
# Installation:
#   cp git-hooks/commit-msg .git/hooks/commit-msg
#   chmod +x .git/hooks/commit-msg
#
# Or via gaia-init (automatic).

COMMIT_MSG_FILE="$1"

if [ ! -f "${COMMIT_MSG_FILE}" ]; then
    exit 0
fi

# Create a temp file for the cleaned message
TEMP_FILE=$(mktemp)
trap 'rm -f "${TEMP_FILE}"' EXIT

# Read the commit message and strip forbidden footer lines:
#   - Co-Authored-By: / Co-authored-with: naming Claude, or the Anthropic
#     model family (Opus / Sonnet / Haiku), or another AI tool (GitHub
#     Copilot, aider, Windsurf, Cursor, Codex, Gemini)
#   - "Generated with Claude Code" / "[Claude Code]" (any case)
#   - Emoji-prefixed "Generated with ..." lines, and a bare robot-emoji line
#   - "Approved-by:" trailers
#   - "Claude-Session:" trailers and the bare claude.ai/code/session URL
sed -E \
    -e '/^[[:space:]]*[Cc][Oo]-[Aa][Uu][Tt][Hh][Oo][Rr][Ee][Dd]-([Bb][Yy]|[Ww][Ii][Tt][Hh]):.*[Cc][Ll][Aa][Uu][Dd][Ee]/d' \
    -e '/^[[:space:]]*[Cc][Oo]-[Aa][Uu][Tt][Hh][Oo][Rr][Ee][Dd]-([Bb][Yy]|[Ww][Ii][Tt][Hh]):.*(Opus|Sonnet|Haiku)/d' \
    -e '/^[[:space:]]*[Cc][Oo]-[Aa][Uu][Tt][Hh][Oo][Rr][Ee][Dd]-([Bb][Yy]|[Ww][Ii][Tt][Hh]):.*(GitHub Copilot|aider|Windsurf|Cursor|Codex|Gemini)/d' \
    -e '/^[[:space:]]*[Gg][Ee][Nn][Ee][Rr][Aa][Tt][Ee][Dd] [Ww][Ii][Tt][Hh].*[Cc][Ll][Aa][Uu][Dd][Ee] [Cc][Oo][Dd][Ee]/d' \
    -e '/^[[:space:]]*..?[[:space:]]*[Gg][Ee][Nn][Ee][Rr][Aa][Tt][Ee][Dd] [Ww][Ii][Tt][Hh]/d' \
    -e '/^[[:space:]]*🤖/d' \
    -e '/^[[:space:]]*[Aa][Pp][Pp][Rr][Oo][Vv][Ee][Dd]-[Bb][Yy]:/d' \
    -e '/^[[:space:]]*[Cc][Ll][Aa][Uu][Dd][Ee]-[Ss][Ee][Ss][Ss][Ii][Oo][Nn]:/d' \
    -e '/claude\.ai\/code\/session/d' \
    "${COMMIT_MSG_FILE}" > "${TEMP_FILE}"

# Remove trailing blank lines (collapse to single trailing newline)
# This prevents empty trailers after stripping
sed -e :a -e '/^\n*$/{$d;N;ba' -e '}' "${TEMP_FILE}" > "${COMMIT_MSG_FILE}"

exit 0
